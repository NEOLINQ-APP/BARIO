# Copy this file to .env.local and fill in real values for local development.
# In Vercel, set these under Project Settings -> Environment Variables.

# Postgres (Neon). Either name works — the app checks DATABASE_URL first.
DATABASE_URL=
POSTGRES_URL=

# Session cookie signing secret — generate with `openssl rand -base64 32`
SESSION_SECRET=

# OpenAI — powers the AI website builder
OPENAI_API_KEY=

# Stripe — subscription billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_AGENCY=

# Resend — transactional email (password reset, email verification)
RESEND_API_KEY=
EMAIL_FROM="Bario <onboarding@resend.dev>"

# Vercel API — used to add/verify/remove custom domains for published sites
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Sentry — error tracking (optional; disabled if unset)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
